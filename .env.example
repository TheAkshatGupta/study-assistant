# Pick ONE provider and fill in its key. Copy this file to .env before running.

# Which provider to use: "groq" | "gemini" | "openrouter" | "openai" | "anthropic" | "ollama"
PROVIDER=groq

# The API key for whichever provider you picked above (not needed for ollama).
API_KEY=

# Optional: override the default model for your provider.
# MODEL=llama-3.1-70b-versatile

# Port the backend listens on (frontend proxies /api here, see vite.config.js)
PORT=8787
